 *
 * Corne Keymap v18
 * Reference: https://zmk.dev/docs/keymaps/behaviors/key-press
 *
 * Changes from v17:
 *  - Removed unused behaviors: sc_oneshot_shift_td, comma_oneshot_ctrl_td
 *  - Removed unused macros: alt_backspace, lm (two-param)
 *  - Added NAV layer (layer 3): numbers + arrows, mirrors Lower
 *    Default rightmost thumb now activates NAV instead of FUNC directly
 *  - FUNC layer moved to layer 4, now requires two deliberate thumbs:
 *      hold right outer thumb (→ NAV) + hold left outer thumb (→ FUNC)
 *  - BT_CLR kept as combo (BT_SEL0 + BT_SEL1) on FUNC for extra safety
 *  - FUNC layer right half: F1–F12 + media controls (was all &trans)
 */

#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/rgb.h>

// ============================================================
// Hardware
// ============================================================

&led_strip {
    chain-length = <27>;
};

// ============================================================
// Layer indices
// ============================================================

#define DEFAULT 0
#define DFT     0
#define LWR     1
#define RSE     2
#define NAV     3
#define FUNC    4

// ============================================================
// Macro aliases
// ============================================================

#define mac_sc  macos_screenshot
#define mac_sca macos_screenshot_with_annotation
#define mac_in  macos_input

// ============================================================
// Macros
// ============================================================

/ {
    macros {

        // Switch macOS input method (Ctrl+Alt+Space)
        macos_input: macos_input {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LCTRL>
                , <&macro_press   &kp LALT>
                , <&macro_tap     &kp SPACE>
                , <&macro_release &kp LALT>
                , <&macro_release &kp LCTRL>
                ;
        };

        // macOS screenshot to clipboard (Cmd+Ctrl+Shift+4)
        macos_screenshot: macos_screenshot {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_press   &kp LCTRL>
                , <&macro_press   &kp LSHFT>
                , <&macro_tap     &kp N4>
                , <&macro_release &kp LSHFT>
                , <&macro_release &kp LCTRL>
                , <&macro_release &kp LGUI>
                ;
        };

        // macOS screenshot with annotation (Cmd+Shift+4)
        macos_screenshot_with_annotation: macos_screenshot_with_annotation {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_press   &kp LSHFT>
                , <&macro_tap     &kp N4>
                , <&macro_release &kp LSHFT>
                , <&macro_release &kp LGUI>
                ;
        };

        // Ctrl+Alt+Arrow macros (workspace/window navigation)
        ctrl_alt_left: ctrl_alt_left {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LCTRL>
                , <&macro_press   &kp LALT>
                , <&macro_tap     &kp LEFT>
                , <&macro_release &kp LALT>
                , <&macro_release &kp LCTRL>
                ;
        };

        ctrl_alt_right: ctrl_alt_right {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LCTRL>
                , <&macro_press   &kp LALT>
                , <&macro_tap     &kp RIGHT>
                , <&macro_release &kp LALT>
                , <&macro_release &kp LCTRL>
                ;
        };

        ctrl_alt_up: ctrl_alt_up {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LCTRL>
                , <&macro_press   &kp LALT>
                , <&macro_tap     &kp UP>
                , <&macro_release &kp LALT>
                , <&macro_release &kp LCTRL>
                ;
        };

        ctrl_alt_down: ctrl_alt_down {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LCTRL>
                , <&macro_press   &kp LALT>
                , <&macro_tap     &kp DOWN>
                , <&macro_release &kp LALT>
                , <&macro_release &kp LCTRL>
                ;
        };

        ctrl_alt_enter: ctrl_alt_enter {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LCTRL>
                , <&macro_press   &kp LALT>
                , <&macro_tap     &kp RET>
                , <&macro_release &kp LALT>
                , <&macro_release &kp LCTRL>
                ;
        };

        // Cmd+` (cycle windows of same app)
        cmd_grave: cmd_grave {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_tap     &kp GRAVE>
                , <&macro_release &kp LGUI>
                ;
        };

        // Cmd+1..5 (switch tabs/spaces)
        cmd_1: cmd_1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_tap     &kp N1>
                , <&macro_release &kp LGUI>
                ;
        };

        cmd_2: cmd_2 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_tap     &kp N2>
                , <&macro_release &kp LGUI>
                ;
        };

        cmd_3: cmd_3 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_tap     &kp N3>
                , <&macro_release &kp LGUI>
                ;
        };

        cmd_4: cmd_4 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_tap     &kp N4>
                , <&macro_release &kp LGUI>
                ;
        };

        cmd_5: cmd_5 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_tap     &kp N5>
                , <&macro_release &kp LGUI>
                ;
        };

        // Zero-param wrapper: hold LWR layer + LGUI simultaneously
        lm_lwr_lgui: lm_lwr_lgui {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <0>;
            tap-ms  = <0>;
            bindings
                = <&macro_press   &mo LWR>
                , <&macro_press   &kp LGUI>
                , <&macro_pause_for_release>
                , <&macro_release &kp LGUI>
                , <&macro_release &mo LWR>
                ;
        };
    };
};

// ============================================================
// Behaviors
// ============================================================

/ {
    behaviors {

        // tap -> ESC   |   hold -> LWR layer + LGUI
        ht_lm_esc: ht_lm_esc {
            compatible = "zmk,behavior-hold-tap";
            label = "HT_LM_ESC";
            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
            bindings = <&lm_lwr_lgui>, <&kp>;
        };

    };
};

// ============================================================
// Combos
// ============================================================

/ {
    combos {
        compatible = "zmk,combos";

        // BT_CLR: press BT_SEL0 + BT_SEL1 simultaneously on FUNC layer
        // Key positions (0-indexed, row-major): 1 = BT_SEL0, 2 = BT_SEL1
        // FUNC is already behind a two-thumb gate; this combo is extra safety.
        combo_bt_clr {
            timeout-ms = <50>;
            key-positions = <1 2>;
            bindings = <&bt BT_CLR>;
            layers = <FUNC>;
        };
    };
};

// ============================================================
// Keymap
// ============================================================

/ {
    keymap {
        compatible = "zmk,keymap";

        // ----------------------------------------------------
        // Layer 0 — Default (QWERTY)
        //
        // ┌──────────┬───┬───┬───┬───┬───┐   ┌───┬───┬───┬───┬───┬──────────┐
        // │TAB/LCTRL │ Q │ W │ E │ R │ T │   │ Y │ U │ I │ O │ P │ SK_RALT  │
        // ├──────────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼──────────┤
        // │ SK_SHFT  │ A │ S │ D │ F │ G │   │ H │ J │ K │ L │ ; │ SK_SHFT  │
        // ├──────────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼──────────┤
        // │ SK_CTRL  │ Z │ X │ C │ V │ B │   │ N │ M │ , │ . │ / │    '     │
        // └──────────┴───┴───┴─┬─┴─┬─┴─┬┘   └┬──┴─┬─┴─┬─┴───┴───┴──────────┘
        //                      │SK │BSP│ESC   │ENT │SPC│ NAV   │
        //                      │GUI│LWR│LWR   │    │RSE│       │
        //                      │   │   │+GUI  │    │   │       │
        //                      └───┴───┘       └────┴───┘
        // ----------------------------------------------------
        default_layer {
            bindings = <
   &mt LCTRL TAB   &kp Q  &kp W  &kp E  &kp R        &kp T          &kp Y    &kp U          &kp I      &kp O    &kp P     &sk RALT
   &sk LSHFT       &kp A  &kp S  &kp D  &kp F        &kp G          &kp H    &kp J          &kp K      &kp L    &kp SEMI  &sk RSHFT
   &sk LCTRL       &kp Z  &kp X  &kp C  &kp V        &kp B          &kp N    &kp M          &kp COMMA  &kp DOT  &kp FSLH  &kp SQT
                                  &sk LGUI  &lt LWR BSPC  &ht_lm_esc 0 ESC   &kp RET  &lt RSE SPACE  &mo NAV
            >;
        };

        // ----------------------------------------------------
        // Layer 1 — Lower  (hold left BSPC thumb)
        //
        // ┌─────┬───┬───┬───┬───┬───┐   ┌───┬───┬───┬───┬───┬─────┐
        // │  `  │ 1 │ 2 │ 3 │ 4 │ 5 │   │ 6 │ 7 │ 8 │ 9 │ 0 │     │
        // ├─────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼─────┤
        // │     │SC │SCA│   │C-b│   │   │ ← │ ↓ │ ↑ │ → │   │     │
        // ├─────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼─────┤
        // │     │   │   │   │   │   │   │   │   │   │   │   │     │
        // └─────┴───┴───┴───┴───┴───┘   └───┴───┴───┴───┴───┴─────┘
        // SC  = macOS screenshot to clipboard (Cmd+Ctrl+Shift+4)
        // SCA = macOS screenshot with annotation (Cmd+Shift+4)
        // ----------------------------------------------------
        lower_layer {
            bindings = <
   &kp GRAVE  &kp N1   &kp N2    &kp N3  &kp N4     &kp N5    &kp N6    &kp N7    &kp N8  &kp N9     &kp N0  &trans
   &trans     &mac_sc  &mac_sca  &trans  &kp LC(B)  &trans    &kp LEFT  &kp DOWN  &kp UP  &kp RIGHT  &trans  &trans
   &trans     &trans   &trans    &trans  &trans     &trans    &trans    &trans    &trans  &trans     &trans  &trans
                                 &trans  &trans     &trans    &trans    &trans    &trans
            >;
        };

        // ----------------------------------------------------
        // Layer 2 — Raise  (hold right SPC thumb)
        //
        // ┌─────┬───┬───┬───┬───┬───┐   ┌───┬───┬───┬───┬───┬─────┐
        // │  ~  │ ! │ @ │ # │ $ │ % │   │ ^ │ & │ * │ ( │ ) │     │
        // ├─────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼─────┤
        // │     │   │   │   │   │   │   │ [ │ - │ = │ ] │ \ │     │
        // ├─────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼─────┤
        // │     │   │   │   │   │   │   │ { │ _ │ + │ } │ | │     │
        // └─────┴───┴───┴───┴───┴───┘   └───┴───┴───┴───┴───┴─────┘
        // ----------------------------------------------------
        raise_layer {
            bindings = <
   &kp TILDE  &kp EXCL  &kp AT  &kp HASH  &kp DLLR  &kp PRCNT    &kp CARET  &kp AMPS   &kp KP_MULTIPLY  &kp LPAR  &kp RPAR  &trans
   &trans     &trans    &trans  &trans    &trans    &trans       &kp LBKT   &kp MINUS  &kp EQUAL        &kp RBKT  &kp BSLH  &trans
   &trans     &trans    &trans  &trans    &trans    &trans       &kp LBRC   &kp UNDER  &kp PLUS         &kp RBRC  &kp PIPE  &trans
                                &trans    &trans    &trans       &trans     &trans     &trans
            >;
        };

        // ----------------------------------------------------
        // Layer 3 — Nav  (hold right outer thumb)
        //
        // Same number row and arrows as Lower. Left outer thumb gates FUNC.
        // Hold right outer thumb (→ NAV) + left outer thumb (→ FUNC) to
        // reach the function/BT/media layer deliberately.
        //
        // ┌──────┬───┬───┬───┬───┬───┐   ┌───┬───┬───┬───┬───┬─────┐
        // │  `   │ 1 │ 2 │ 3 │ 4 │ 5 │   │ 6 │ 7 │ 8 │ 9 │ 0 │     │
        // ├──────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼─────┤
        // │      │SC │SCA│   │C-b│   │   │ ← │ ↓ │ ↑ │ → │   │     │
        // ├──────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼─────┤
        // │      │   │   │   │   │   │   │   │   │   │   │   │     │
        // └──────┴───┴───┴───┴───┴───┘   └───┴───┴───┴───┴───┴─────┘
        //               │FUNC│    │    │   │    │    │(held)│
        // ----------------------------------------------------
        nav_layer {
            bindings = <
   &kp GRAVE  &kp N1   &kp N2    &kp N3  &kp N4     &kp N5    &kp N6    &kp N7    &kp N8  &kp N9     &kp N0  &trans
   &trans     &mac_sc  &mac_sca  &trans  &kp LC(B)  &trans    &kp LEFT  &kp DOWN  &kp UP  &kp RIGHT  &trans  &trans
   &trans     &trans   &trans    &trans  &trans     &trans    &trans    &trans    &trans  &trans     &trans  &trans
                                 &mo FUNC  &trans   &trans    &trans    &trans    &trans
            >;
        };

        // ----------------------------------------------------
        // Layer 4 — Func  (NAV + left outer thumb)
        //
        // Requires two deliberate thumb holds to reach. BT_CLR is
        // additionally guarded by a combo (BT_SEL0 + BT_SEL1).
        //
        // ┌─────┬────┬────┬────┬────┬────┐   ┌────┬────┬────┬────┬────┬────┐
        // │     │BT0 │BT1 │BT2 │BT3 │BT4 │   │ F1 │ F2 │ F3 │ F4 │ F5 │ F6 │
        // ├─────┼────┼────┼────┼────┼────┤   ├────┼────┼────┼────┼────┼────┤
        // │     │    │    │    │    │    │   │ F7 │ F8 │ F9 │F10 │F11 │F12 │
        // ├─────┼────┼────┼────┼────┼────┤   ├────┼────┼────┼────┼────┼────┤
        // │     │TOG │EFF │HUI │HUD │    │   │    │MUTE│VOLD│VOLU│PREV│NEXT│
        // └─────┴────┴────┴────┴────┴────┘   └────┴────┴────┴────┴────┴────┘
        //               │(held)│    │    │   │ PP │    │    │
        //
        // BT0-4  = select Bluetooth profile 0-4
        // BTCLR  = combo BT0+BT1 simultaneously
        // TOG    = toggle RGB underglow on/off
        // EFF    = cycle RGB effect
        // HUI/D  = hue increase / decrease
        // MUTE   = mute/unmute
        // VOLD/U = volume down / up
        // PREV/NEXT = media previous / next track
        // PP     = play / pause
        // ----------------------------------------------------
        func_layer {
            bindings = <
   &trans  &bt BT_SEL 0     &bt BT_SEL 1     &bt BT_SEL 2     &bt BT_SEL 3     &bt BT_SEL 4    &kp F1    &kp F2       &kp F3        &kp F4        &kp F5      &kp F6
   &trans  &trans           &trans           &trans           &trans           &trans          &kp F7    &kp F8       &kp F9        &kp F10       &kp F11     &kp F12
   &trans  &rgb_ug RGB_TOG  &rgb_ug RGB_EFF  &rgb_ug RGB_HUI  &rgb_ug RGB_HUD  &trans          &trans    &kp C_MUTE   &kp C_VOL_DN  &kp C_VOL_UP  &kp C_PREV  &kp C_NEXT
                                             &trans           &trans           &trans          &kp C_PP  &trans       &trans
            >;
        };

        // ----------------------------------------------------
        // Layer 5 — Template  (unused / reserved)
        // ----------------------------------------------------
        template_layer {
            bindings = <
   &trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
   &trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
   &trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
                           &trans  &trans  &trans    &trans  &trans  &trans
            >;
        };
    };
};
