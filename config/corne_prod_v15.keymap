#include <behaviors.dtsi>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/rgb.h>

// ============================================================
// Hardware
// ============================================================

&led_strip {
    chain-length = <27>;
};

// ============================================================
// Layer indices
// ============================================================

#define DEFAULT 0
#define DFT     0
#define LWR     1
#define RSE     2
#define FUNC    3

// ============================================================
// Macro aliases
// ============================================================

#define mac_sc  macos_screenshot
#define mac_sca macos_screenshot_with_annotation
#define mac_in  macos_input

// ============================================================
// Macros
// ============================================================

/ {
    macros {

        // Switch macOS input method (Ctrl+Alt+Space)
        macos_input: macos_input {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LCTRL>
                , <&macro_press   &kp LALT>
                , <&macro_tap     &kp SPACE>
                , <&macro_release &kp LALT>
                , <&macro_release &kp LCTRL>
                ;
        };

        // Alt+Backspace (delete previous word)
        alt_backspace: alt_backspace {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LALT>
                , <&macro_tap     &kp BSPC>
                , <&macro_release &kp LALT>
                ;
        };

        // macOS screenshot to clipboard (Cmd+Ctrl+Shift+4)
        macos_screenshot: macos_screenshot {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_press   &kp LCTRL>
                , <&macro_press   &kp LSHFT>
                , <&macro_tap     &kp N4>
                , <&macro_release &kp LSHFT>
                , <&macro_release &kp LCTRL>
                , <&macro_release &kp LGUI>
                ;
        };

        // macOS screenshot with annotation (Cmd+Shift+4)
        macos_screenshot_with_annotation: macos_screenshot_with_annotation {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_press   &kp LSHFT>
                , <&macro_tap     &kp N4>
                , <&macro_release &kp LSHFT>
                , <&macro_release &kp LGUI>
                ;
        };

        // Ctrl+Alt+Arrow macros (workspace/window navigation)
        ctrl_alt_left: ctrl_alt_left {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LCTRL>
                , <&macro_press   &kp LALT>
                , <&macro_tap     &kp LEFT>
                , <&macro_release &kp LALT>
                , <&macro_release &kp LCTRL>
                ;
        };

        ctrl_alt_right: ctrl_alt_right {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LCTRL>
                , <&macro_press   &kp LALT>
                , <&macro_tap     &kp RIGHT>
                , <&macro_release &kp LALT>
                , <&macro_release &kp LCTRL>
                ;
        };

        ctrl_alt_up: ctrl_alt_up {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LCTRL>
                , <&macro_press   &kp LALT>
                , <&macro_tap     &kp UP>
                , <&macro_release &kp LALT>
                , <&macro_release &kp LCTRL>
                ;
        };

        ctrl_alt_down: ctrl_alt_down {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LCTRL>
                , <&macro_press   &kp LALT>
                , <&macro_tap     &kp DOWN>
                , <&macro_release &kp LALT>
                , <&macro_release &kp LCTRL>
                ;
        };

        ctrl_alt_enter: ctrl_alt_enter {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LCTRL>
                , <&macro_press   &kp LALT>
                , <&macro_tap     &kp RET>
                , <&macro_release &kp LALT>
                , <&macro_release &kp LCTRL>
                ;
        };

        // Cmd+` (cycle windows of same app)
        cmd_grave: cmd_grave {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_tap     &kp GRAVE>
                , <&macro_release &kp LGUI>
                ;
        };

        // Cmd+1..5 (switch tabs/spaces)
        cmd_1: cmd_1 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_tap     &kp N1>
                , <&macro_release &kp LGUI>
                ;
        };

        cmd_2: cmd_2 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_tap     &kp N2>
                , <&macro_release &kp LGUI>
                ;
        };

        cmd_3: cmd_3 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_tap     &kp N3>
                , <&macro_release &kp LGUI>
                ;
        };

        cmd_4: cmd_4 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_tap     &kp N4>
                , <&macro_release &kp LGUI>
                ;
        };

        cmd_5: cmd_5 {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            bindings
                = <&macro_press   &kp LGUI>
                , <&macro_tap     &kp N5>
                , <&macro_release &kp LGUI>
                ;
        };

        /*
         * lm — hold a layer while a modifier is active (QMK LM() equivalent)
         *   param 1: layer index
         *   param 2: modifier key
         * Example: &lm LWR LGUI
         */
        lm: lm {
            compatible = "zmk,behavior-macro-two-param";
            wait-ms = <0>;
            tap-ms  = <0>;
            #binding-cells = <2>;
            bindings
                = <&macro_param_1to1>
                , <&macro_press   &mo MACRO_PLACEHOLDER>
                , <&macro_param_2to1>
                , <&macro_press   &kp MACRO_PLACEHOLDER>
                , <&macro_pause_for_release>
                , <&macro_param_2to1>
                , <&macro_release &kp MACRO_PLACEHOLDER>
                , <&macro_param_1to1>
                , <&macro_release &mo MACRO_PLACEHOLDER>
                ;
        };
    };
};

// ============================================================
// Tap-dance behaviors
// ============================================================

/ {
    behaviors {

        // 1 tap -> ;   |   2 taps -> one-shot Shift
        sc_oneshot_shift_td: sc_oneshot_shift_td {
            compatible = "zmk,behavior-tap-dance";
            label = "SC_OS_SHIFT_TD";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp SEMI>, <&sk LSHFT>;
        };

        // 1 tap -> ,   |   2 taps -> one-shot Ctrl
        comma_oneshot_ctrl_td: comma_oneshot_ctrl_td {
            compatible = "zmk,behavior-tap-dance";
            label = "COMMA_OS_CTRL_TD";
            #binding-cells = <0>;
            tapping-term-ms = <200>;
            bindings = <&kp COMMA>, <&sk LCTRL>;
        };
    };
};

// ============================================================
// Keymap
// ============================================================

/ {
    keymap {
        compatible = "zmk,keymap";

        // ----------------------------------------------------
        // Layer 0 — Default (QWERTY)
        //
        // ┌──────────┬───┬───┬───┬───┬───┐   ┌───┬───┬───┬───┬───┬──────────┐
        // │TAB/LCTRL │ Q │ W │ E │ R │ T │   │ Y │ U │ I │ O │ P │BSPC/RALT │
        // ├──────────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼──────────┤
        // │ ESC/LSHFT│ A │ S │ D │ F │ G │   │ H │ J │ K │ L │ ; │  RSHFT   │
        // ├──────────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼──────────┤
        // │    `     │ Z │ X │ C │ V │ B │   │ N │ M │ , │ . │ / │    '     │
        // └──────────┴───┴───┴─┬─┴─┬─┴─┬┘   └┬──┴─┬─┴─┬─┴───┴───┴──────────┘
        //                      │GUI│BSP│LWR   │ENT │SPC│FUNC
        //                      │   │LWR│+GUI  │    │RSE│
        //                      └───┴───┘       └────┴───┘
        // ----------------------------------------------------
        default_layer {
            bindings = <
   &mt LCTRL TAB   &kp Q  &kp W  &kp E  &kp R        &kp T          &kp Y    &kp U          &kp I      &kp O    &kp P     &mt RALT BSPC
   &mt LSHFT ESC   &kp A  &kp S  &kp D  &kp F        &kp G          &kp H    &kp J          &kp K      &kp L    &kp SEMI  &kp RSHFT
   &kp GRAVE       &kp Z  &kp X  &kp C  &kp V        &kp B          &kp N    &kp M          &kp COMMA  &kp DOT  &kp FSLH  &kp SQT
                                  &kp LGUI  &lt LWR BSPC  &lm LWR LGUI   &kp RET  &lt RSE SPACE  &mo FUNC
            >;
        };

        // ----------------------------------------------------
        // Layer 1 — Lower  (hold left BSPC thumb)
        //
        // ┌─────┬───┬───┬───┬───┬───┐   ┌───┬───┬───┬───┬───┬─────┐
        // │  `  │ 1 │ 2 │ 3 │ 4 │ 5 │   │ 6 │ 7 │ 8 │ 9 │ 0 │     │
        // ├─────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼─────┤
        // │     │SC │SCA│   │   │   │   │ ← │ ↓ │ ↑ │ → │   │     │
        // ├─────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼─────┤
        // │     │   │   │   │   │   │   │   │   │   │   │   │     │
        // └─────┴───┴───┴───┴───┴───┘   └───┴───┴───┴───┴───┴─────┘
        // SC  = macOS screenshot to clipboard (Cmd+Ctrl+Shift+4)
        // SCA = macOS screenshot with annotation (Cmd+Shift+4)
        // ----------------------------------------------------
        lower_layer {
            bindings = <
   &kp GRAVE  &kp N1   &kp N2    &kp N3  &kp N4  &kp N5    &kp N6    &kp N7    &kp N8  &kp N9     &kp N0  &trans
   &trans     &mac_sc  &mac_sca  &trans  &trans  &trans    &kp LEFT  &kp DOWN  &kp UP  &kp RIGHT  &trans  &trans
   &trans     &trans   &trans    &trans  &trans  &trans    &trans    &trans    &trans  &trans     &trans  &trans
                                 &trans  &trans  &trans    &trans    &trans    &trans
            >;
        };

        // ----------------------------------------------------
        // Layer 2 — Raise  (hold right SPC thumb)
        //
        // ┌─────┬───┬───┬───┬───┬───┐   ┌───┬───┬───┬───┬───┬─────┐
        // │  ~  │ ! │ @ │ # │ $ │ % │   │ ^ │ & │ * │ ( │ ) │     │
        // ├─────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼─────┤
        // │     │   │   │   │   │   │   │ [ │ - │ = │ ] │ \ │     │
        // ├─────┼───┼───┼───┼───┼───┤   ├───┼───┼───┼───┼───┼─────┤
        // │     │   │   │   │   │   │   │ { │ _ │ + │ } │ | │     │
        // └─────┴───┴───┴───┴───┴───┘   └───┴───┴───┴───┴───┴─────┘
        // ----------------------------------------------------
        raise_layer {
            bindings = <
   &kp TILDE  &kp EXCL  &kp AT  &kp HASH  &kp DLLR  &kp PRCNT    &kp CARET  &kp AMPS   &kp KP_MULTIPLY  &kp LPAR  &kp RPAR  &trans
   &trans     &trans    &trans  &trans    &trans    &trans       &kp LBKT   &kp MINUS  &kp EQUAL        &kp RBKT  &kp BSLH  &trans
   &trans     &trans    &trans  &trans    &trans    &trans       &kp LBRC   &kp UNDER  &kp PLUS         &kp RBRC  &kp PIPE  &trans
                                &trans    &trans    &trans       &trans     &trans     &trans
            >;
        };

        // ----------------------------------------------------
        // Layer 3 — Func  (hold rightmost thumb)
        //
        // ┌─────┬────┬────┬────┬────┬────┐   ┌──────┬───┬───┬───┬───┬─────┐
        // │     │BT0 │BT1 │BT2 │BT3 │BT4 │   │BTCLR │   │   │   │   │     │
        // ├─────┼────┼────┼────┼────┼────┤   ├──────┼───┼───┼───┼───┼─────┤
        // │     │    │    │    │    │    │   │      │   │   │   │   │     │
        // ├─────┼────┼────┼────┼────┼────┤   ├──────┼───┼───┼───┼───┼─────┤
        // │     │TOG │EFF │HUI │HUD │    │   │      │   │   │   │   │     │
        // └─────┴────┴────┴────┴────┴────┘   └──────┴───┴───┴───┴───┴─────┘
        // BT0-4 = select Bluetooth profile 0-4
        // BTCLR = clear current BT pairing
        // TOG   = toggle RGB underglow on/off
        // EFF   = cycle RGB effect
        // HUI/D = hue increase / decrease
        // ----------------------------------------------------
        func_layer {
            bindings = <
   &trans  &bt BT_SEL 0     &bt BT_SEL 1     &bt BT_SEL 2     &bt BT_SEL 3     &bt BT_SEL 4    &bt BT_CLR  &trans  &trans  &trans  &trans  &trans
   &trans  &trans           &trans           &trans           &trans           &trans          &trans      &trans  &trans  &trans  &trans  &trans
   &trans  &rgb_ug RGB_TOG  &rgb_ug RGB_EFF  &rgb_ug RGB_HUI  &rgb_ug RGB_HUD  &trans          &trans      &trans  &trans  &trans  &trans  &trans
                                             &trans           &trans           &trans          &trans      &trans  &trans
            >;
        };

        // ----------------------------------------------------
        // Layer 4 — Template  (unused / reserved)
        // ----------------------------------------------------
        template_layer {
            bindings = <
   &trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
   &trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
   &trans  &trans  &trans  &trans  &trans  &trans    &trans  &trans  &trans  &trans  &trans  &trans
                           &trans  &trans  &trans    &trans  &trans  &trans
            >;
        };
    };
};
